# Copy this file to .env and fill in your values
# cp .env.example .env

# === Database ===
# Lokálne: SQLite súbor. Na Streamlit Cloud SQLite nefunguje spoľahlivo — kontajner
# je efemérny a redeploy (pri každom git push) vymaže celú DB. Pre produkciu nastav
# tento DATABASE_URL ako Streamlit secret na Postgres, napr. Supabase:
#   DATABASE_URL=postgresql://postgres:<heslo>@<host>:5432/postgres
DATABASE_URL=sqlite:///data/trendy.db

# === Data inbox paths (relative to project root) ===
AHREFS_INBOX_DIR=data/ahrefs_inbox
GSC_INBOX_DIR=data/gsc_inbox
CLUSTERS_DIR=data/clusters

# === Portal URLs (used for sitemap scraping) ===
PORTAL_MSG_LIFE_URL=https://www.msg-life.sk
PORTAL_MSGTESTER_URL=https://msgtester.sk
PORTAL_MSGPROGRAMATOR_URL=https://msgprogramator.sk

# === Scoring weights (must sum to 1.0) ===
WEIGHT_VOLUME=0.25
WEIGHT_GROWTH=0.35
WEIGHT_GAP=0.25
WEIGHT_OPPORTUNITY=0.15

# === Volume thresholds per portal (min searches/month) ===
THRESHOLD_MSG_LIFE=30
THRESHOLD_MSGTESTER=10
THRESHOLD_MSGPROGRAMATOR=15

# === Lifecycle cooldowns (in days) ===
COOLDOWN_REJECTED_DAYS=90
COOLDOWN_PUBLISHED_DAYS=365
SNOOZE_DEFAULT_DAYS=30

# === Google Trends ===
PYTRENDS_RATE_LIMIT_SECONDS=6
PYTRENDS_LANGUAGE=sk
PYTRENDS_GEO=SK

# === Scheduler ===
# Mesačný refresh: deň v mesiaci (1-31), hodina, minúta
SCHEDULER_CRON_HOUR=6
SCHEDULER_CRON_MINUTE=0
SCHEDULER_CRON_DAY=1

# === LLM: Google Gemini (pre GSC rising analýzu, RSS summarization, LLM probing) ===
# Bezplatný kľúč: https://aistudio.google.com/apikey (Google účet, bez karty)
GEMINI_API_KEY=
# Voliteľné — prepíše default model (gemini-2.5-flash):
# GEMINI_MODEL=gemini-2.5-flash

# === Reddit API (PRAW) — https://www.reddit.com/prefs/apps ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Trendy-bot/1.0

# === Perplexity API (voliteľné — web-grounded trending topics) ===
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# === SerpAPI (voliteľné — People Also Ask + related searches z Google SK) ===
# https://serpapi.com/manage-api-key
SERPAPI_API_KEY=

# === Future: GSC API (disabled v MVP — uncomment when available) ===
# GSC_SERVICE_ACCOUNT_JSON=secrets/gsc-service-account.json
# GSC_MSG_LIFE_PROPERTY=sc-domain:msg-life.sk
# GSC_MSGTESTER_PROPERTY=sc-domain:msgtester.sk
# GSC_MSGPROGRAMATOR_PROPERTY=sc-domain:msgprogramator.sk

# === Future: Ahrefs MCP (stub — uncomment when MCP connector is active) ===
# AHREFS_MCP_ENABLED=true
